{
  "surah": {
    "number": 80,
    "name_arabic": "سُورَةُ عَبَسَ",
    "name_bangla": "আবাসা",
    "name_english": "Abasa",
    "name_meaning": "He frowned",
    "ayah_count": 42,
    "juz_start": 30,
    "revelation_type": "meccan"
  },
  "ayahs": [
    {
      "surah_number": 80,
      "ayah_number": 1,
      "arabic_text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ عَبَسَ وَتَوَلَّىٰ",
      "bangla_translation": "তিনি ভ্রূকুঞ্চিত করলেন এবং মুখ ফিরিয়ে নিলেন।",
      "english_translation": "The Prophet frowned and turned away",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 2,
      "arabic_text": "أَنْ جَاءَهُ الْأَعْمَىٰ",
      "bangla_translation": "কারণ, তাঁর কাছে এক অন্ধ আগমন করল।",
      "english_translation": "Because there came to him the blind man, [interrupting].",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 3,
      "arabic_text": "وَمَا يُدْرِيكَ لَعَلَّهُ يَزَّكَّىٰ",
      "bangla_translation": "আপনি কি জানেন, সে হয়তো পরিশুদ্ধ হত,",
      "english_translation": "But what would make you perceive, [O Muhammad], that perhaps he might be purified",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 4,
      "arabic_text": "أَوْ يَذَّكَّرُ فَتَنْفَعَهُ الذِّكْرَىٰ",
      "bangla_translation": "অথবা উপদেশ গ্রহণ করতো এবং উপদেশ তার উপকার হত।",
      "english_translation": "Or be reminded and the remembrance would benefit him?",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 5,
      "arabic_text": "أَمَّا مَنِ اسْتَغْنَىٰ",
      "bangla_translation": "পরন্তু যে বেপরোয়া,",
      "english_translation": "As for he who thinks himself without need,",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 6,
      "arabic_text": "فَأَنْتَ لَهُ تَصَدَّىٰ",
      "bangla_translation": "আপনি তার চিন্তায় মশগুল।",
      "english_translation": "To him you give attention.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 7,
      "arabic_text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
      "bangla_translation": "সে শুদ্ধ না হলে আপনার কোন দোষ নেই।",
      "english_translation": "And not upon you [is any blame] if he will not be purified.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 8,
      "arabic_text": "وَأَمَّا مَنْ جَاءَكَ يَسْعَىٰ",
      "bangla_translation": "যে আপনার কাছে দৌড়ে আসলো",
      "english_translation": "But as for he who came to you striving [for knowledge]",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 9,
      "arabic_text": "وَهُوَ يَخْشَىٰ",
      "bangla_translation": "এমতাবস্থায় যে, সে ভয় করে,",
      "english_translation": "While he fears [Allah],",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 10,
      "arabic_text": "فَأَنْتَ عَنْهُ تَلَهَّىٰ",
      "bangla_translation": "আপনি তাকে অবজ্ঞা করলেন।",
      "english_translation": "From him you are distracted.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 11,
      "arabic_text": "كَلَّا إِنَّهَا تَذْكِرَةٌ",
      "bangla_translation": "কখনও এরূপ করবেন না, এটা উপদেশবানী।",
      "english_translation": "No! Indeed, these verses are a reminder;",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 12,
      "arabic_text": "فَمَنْ شَاءَ ذَكَرَهُ",
      "bangla_translation": "অতএব, যে ইচ্ছা করবে, সে একে গ্রহণ করবে।",
      "english_translation": "So whoever wills may remember it.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 13,
      "arabic_text": "فِي صُحُفٍ مُكَرَّمَةٍ",
      "bangla_translation": "এটা লিখিত আছে সম্মানিত,",
      "english_translation": "[It is recorded] in honored sheets,",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 14,
      "arabic_text": "مَرْفُوعَةٍ مُطَهَّرَةٍ",
      "bangla_translation": "উচ্চ পবিত্র পত্রসমূহে,",
      "english_translation": "Exalted and purified,",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 15,
      "arabic_text": "بِأَيْدِي سَفَرَةٍ",
      "bangla_translation": "লিপিকারের হস্তে,",
      "english_translation": "[Carried] by the hands of messenger-angels,",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 16,
      "arabic_text": "كِرَامٍ بَرَرَةٍ",
      "bangla_translation": "যারা মহৎ, পূত চরিত্র।",
      "english_translation": "Noble and dutiful.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 17,
      "arabic_text": "قُتِلَ الْإِنْسَانُ مَا أَكْفَرَهُ",
      "bangla_translation": "মানুষ ধ্বংস হোক, সে কত অকৃতজ্ঞ!",
      "english_translation": "Cursed is man; how disbelieving is he.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 18,
      "arabic_text": "مِنْ أَيِّ شَيْءٍ خَلَقَهُ",
      "bangla_translation": "তিনি তাকে কি বস্তু থেকে সৃষ্টি করেছেন?",
      "english_translation": "From what substance did He create him?",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 19,
      "arabic_text": "مِنْ نُطْفَةٍ خَلَقَهُ فَقَدَّرَهُ",
      "bangla_translation": "শুক্র থেকে তাকে সৃষ্টি করেছেন, অতঃপর তাকে সুপরিমিত করেছেন।",
      "english_translation": "From a sperm-drop He created him and destined for him;",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 20,
      "arabic_text": "ثُمَّ السَّبِيلَ يَسَّرَهُ",
      "bangla_translation": "অতঃপর তার পথ সহজ করেছেন,",
      "english_translation": "Then He eased the way for him;",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 21,
      "arabic_text": "ثُمَّ أَمَاتَهُ فَأَقْبَرَهُ",
      "bangla_translation": "অতঃপর তার মৃত্যু ঘটান ও কবরস্থ করেন তাকে।",
      "english_translation": "Then He causes his death and provides a grave for him.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 22,
      "arabic_text": "ثُمَّ إِذَا شَاءَ أَنْشَرَهُ",
      "bangla_translation": "এরপর যখন ইচ্ছা করবেন তখন তাকে পুনরুজ্জীবিত করবেন।",
      "english_translation": "Then when He wills, He will resurrect him.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 23,
      "arabic_text": "كَلَّا لَمَّا يَقْضِ مَا أَمَرَهُ",
      "bangla_translation": "সে কখনও কৃতজ্ঞ হয়নি, তিনি তাকে যা আদেশ করেছেন, সে তা পূর্ণ করেনি।",
      "english_translation": "No! Man has not yet accomplished what He commanded him.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 24,
      "arabic_text": "فَلْيَنْظُرِ الْإِنْسَانُ إِلَىٰ طَعَامِهِ",
      "bangla_translation": "মানুষ তার খাদ্যের প্রতি লক্ষ্য করুক,",
      "english_translation": "Then let mankind look at his food -",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 25,
      "arabic_text": "أَنَّا صَبَبْنَا الْمَاءَ صَبًّا",
      "bangla_translation": "আমি আশ্চর্য উপায়ে পানি বর্ষণ করেছি,",
      "english_translation": "How We poured down water in torrents,",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 26,
      "arabic_text": "ثُمَّ شَقَقْنَا الْأَرْضَ شَقًّا",
      "bangla_translation": "এরপর আমি ভূমিকে বিদীর্ণ করেছি,",
      "english_translation": "Then We broke open the earth, splitting [it with sprouts],",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 27,
      "arabic_text": "فَأَنْبَتْنَا فِيهَا حَبًّا",
      "bangla_translation": "অতঃপর তাতে উৎপন্ন করেছি শস্য,",
      "english_translation": "And caused to grow within it grain",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 28,
      "arabic_text": "وَعِنَبًا وَقَضْبًا",
      "bangla_translation": "আঙ্গুর, শাক-সব্জি,",
      "english_translation": "And grapes and herbage",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 29,
      "arabic_text": "وَزَيْتُونًا وَنَخْلًا",
      "bangla_translation": "যয়তুন, খর্জূর,",
      "english_translation": "And olive and palm trees",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 30,
      "arabic_text": "وَحَدَائِقَ غُلْبًا",
      "bangla_translation": "ঘন উদ্যান,",
      "english_translation": "And gardens of dense shrubbery",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 31,
      "arabic_text": "وَفَاكِهَةً وَأَبًّا",
      "bangla_translation": "ফল এবং ঘাস",
      "english_translation": "And fruit and grass -",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 32,
      "arabic_text": "مَتَاعًا لَكُمْ وَلِأَنْعَامِكُمْ",
      "bangla_translation": "তোমাদেরও তোমাদের চতুস্পদ জন্তুদের উপাকারার্থে।",
      "english_translation": "[As] enjoyment for you and your grazing livestock.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 33,
      "arabic_text": "فَإِذَا جَاءَتِ الصَّاخَّةُ",
      "bangla_translation": "অতঃপর যেদিন কর্ণবিদারক নাদ আসবে,",
      "english_translation": "But when there comes the Deafening Blast",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 34,
      "arabic_text": "يَوْمَ يَفِرُّ الْمَرْءُ مِنْ أَخِيهِ",
      "bangla_translation": "সেদিন পলায়ন করবে মানুষ তার ভ্রাতার কাছ থেকে,",
      "english_translation": "On the Day a man will flee from his brother",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 35,
      "arabic_text": "وَأُمِّهِ وَأَبِيهِ",
      "bangla_translation": "তার মাতা, তার পিতা,",
      "english_translation": "And his mother and his father",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 36,
      "arabic_text": "وَصَاحِبَتِهِ وَبَنِيهِ",
      "bangla_translation": "তার পত্নী ও তার সন্তানদের কাছ থেকে।",
      "english_translation": "And his wife and his children,",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 37,
      "arabic_text": "لِكُلِّ امْرِئٍ مِنْهُمْ يَوْمَئِذٍ شَأْنٌ يُغْنِيهِ",
      "bangla_translation": "সেদিন প্রত্যেকেরই নিজের এক চিন্তা থাকবে, যা তাকে ব্যতিব্যস্ত করে রাখবে।",
      "english_translation": "For every man, that Day, will be a matter adequate for him.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 38,
      "arabic_text": "وُجُوهٌ يَوْمَئِذٍ مُسْفِرَةٌ",
      "bangla_translation": "অনেক মুখমন্ডল সেদিন হবে উজ্জ্বল,",
      "english_translation": "[Some] faces, that Day, will be bright -",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 39,
      "arabic_text": "ضَاحِكَةٌ مُسْتَبْشِرَةٌ",
      "bangla_translation": "সহাস্য ও প্রফুল্ল।",
      "english_translation": "Laughing, rejoicing at good news.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 40,
      "arabic_text": "وَوُجُوهٌ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌ",
      "bangla_translation": "এবং অনেক মুখমন্ডল সেদিন হবে ধুলি ধূসরিত।",
      "english_translation": "And [other] faces, that Day, will have upon them dust.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 41,
      "arabic_text": "تَرْهَقُهَا قَتَرَةٌ",
      "bangla_translation": "তাদেরকে কালিমা আচ্ছন্ন করে রাখবে।",
      "english_translation": "Blackness will cover them.",
      "juz_number": 30,
      "page_number": 585
    },
    {
      "surah_number": 80,
      "ayah_number": 42,
      "arabic_text": "أُولَٰئِكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ",
      "bangla_translation": "তারাই কাফের পাপিষ্ঠের দল।",
      "english_translation": "Those are the disbelievers, the wicked ones.",
      "juz_number": 30,
      "page_number": 585
    }
  ]
}
