{
  "surah": {
    "number": 86,
    "name_arabic": "سُورَةُ الطَّارِقِ",
    "name_bangla": "আত-তারিক",
    "name_english": "At-Taariq",
    "name_meaning": "The Morning Star",
    "ayah_count": 17,
    "juz_start": 30,
    "revelation_type": "meccan"
  },
  "ayahs": [
    {
      "surah_number": 86,
      "ayah_number": 1,
      "arabic_text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ وَالسَّمَاءِ وَالطَّارِقِ",
      "bangla_translation": "শপথ আকাশের এবং রাত্রিতে আগমনকারীর।",
      "english_translation": "By the sky and the night comer -",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 2,
      "arabic_text": "وَمَا أَدْرَاكَ مَا الطَّارِقُ",
      "bangla_translation": "আপনি জানেন, যে রাত্রিতে আসে সেটা কি?",
      "english_translation": "And what can make you know what is the night comer?",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 3,
      "arabic_text": "النَّجْمُ الثَّاقِبُ",
      "bangla_translation": "সেটা এক উজ্জ্বল নক্ষত্র।",
      "english_translation": "It is the piercing star -",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 4,
      "arabic_text": "إِنْ كُلُّ نَفْسٍ لَمَّا عَلَيْهَا حَافِظٌ",
      "bangla_translation": "প্রত্যেকের উপর একজন তত্ত্বাবধায়ক রয়েছে।",
      "english_translation": "There is no soul but that it has over it a protector.",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 5,
      "arabic_text": "فَلْيَنْظُرِ الْإِنْسَانُ مِمَّ خُلِقَ",
      "bangla_translation": "অতএব, মানুষের দেখা উচিত কি বস্তু থেকে সে সৃজিত হয়েছে।",
      "english_translation": "So let man observe from what he was created.",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 6,
      "arabic_text": "خُلِقَ مِنْ مَاءٍ دَافِقٍ",
      "bangla_translation": "সে সৃজিত হয়েছে সবেগে স্খলিত পানি থেকে।",
      "english_translation": "He was created from a fluid, ejected,",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 7,
      "arabic_text": "يَخْرُجُ مِنْ بَيْنِ الصُّلْبِ وَالتَّرَائِبِ",
      "bangla_translation": "এটা নির্গত হয় মেরুদন্ড ও বক্ষপাজরের মধ্য থেকে।",
      "english_translation": "Emerging from between the backbone and the ribs.",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 8,
      "arabic_text": "إِنَّهُ عَلَىٰ رَجْعِهِ لَقَادِرٌ",
      "bangla_translation": "নিশ্চয় তিনি তাকে ফিরিয়ে নিতে সক্ষম।",
      "english_translation": "Indeed, Allah, to return him [to life], is Able.",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 9,
      "arabic_text": "يَوْمَ تُبْلَى السَّرَائِرُ",
      "bangla_translation": "যেদিন গোপন বিষয়াদি পরীক্ষিত হবে,",
      "english_translation": "The Day when secrets will be put on trial,",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 10,
      "arabic_text": "فَمَا لَهُ مِنْ قُوَّةٍ وَلَا نَاصِرٍ",
      "bangla_translation": "সেদিন তার কোন শক্তি থাকবে না এবং সাহায্যকারীও থাকবে না।",
      "english_translation": "Then man will have no power or any helper.",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 11,
      "arabic_text": "وَالسَّمَاءِ ذَاتِ الرَّجْعِ",
      "bangla_translation": "শপথ চক্রশীল আকাশের",
      "english_translation": "By the sky which returns [rain]",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 12,
      "arabic_text": "وَالْأَرْضِ ذَاتِ الصَّدْعِ",
      "bangla_translation": "এবং বিদারনশীল পৃথিবীর",
      "english_translation": "And [by] the earth which cracks open,",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 13,
      "arabic_text": "إِنَّهُ لَقَوْلٌ فَصْلٌ",
      "bangla_translation": "নিশ্চয় কোরআন সত্য-মিথ্যার ফয়সালা।",
      "english_translation": "Indeed, the Qur'an is a decisive statement,",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 14,
      "arabic_text": "وَمَا هُوَ بِالْهَزْلِ",
      "bangla_translation": "এবং এটা উপহাস নয়।",
      "english_translation": "And it is not amusement.",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 15,
      "arabic_text": "إِنَّهُمْ يَكِيدُونَ كَيْدًا",
      "bangla_translation": "তারা ভীষণ চক্রান্ত করে,",
      "english_translation": "Indeed, they are planning a plan,",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 16,
      "arabic_text": "وَأَكِيدُ كَيْدًا",
      "bangla_translation": "আর আমিও কৌশল করি।",
      "english_translation": "But I am planning a plan.",
      "juz_number": 30,
      "page_number": 591
    },
    {
      "surah_number": 86,
      "ayah_number": 17,
      "arabic_text": "فَمَهِّلِ الْكَافِرِينَ أَمْهِلْهُمْ رُوَيْدًا",
      "bangla_translation": "অতএব, কাফেরদেরকে অবকাশ দিন, তাদেরকে অবকাশ দিন, কিছু দিনের জন্যে।",
      "english_translation": "So allow time for the disbelievers. Leave them awhile.",
      "juz_number": 30,
      "page_number": 591
    }
  ]
}
