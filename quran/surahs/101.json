{
  "surah": {
    "number": 101,
    "name_arabic": "سُورَةُ القَارِعَةِ",
    "name_bangla": "আল-কারিআহ",
    "name_english": "Al-Qaari'a",
    "name_meaning": "The Calamity",
    "ayah_count": 11,
    "juz_start": 30,
    "revelation_type": "meccan"
  },
  "ayahs": [
    {
      "surah_number": 101,
      "ayah_number": 1,
      "arabic_text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ الْقَارِعَةُ",
      "bangla_translation": "করাঘাতকারী,",
      "english_translation": "The Striking Calamity -",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 2,
      "arabic_text": "مَا الْقَارِعَةُ",
      "bangla_translation": "করাঘাতকারী কি?",
      "english_translation": "What is the Striking Calamity?",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 3,
      "arabic_text": "وَمَا أَدْرَاكَ مَا الْقَارِعَةُ",
      "bangla_translation": "করাঘাতকারী সম্পর্কে আপনি কি জানেন ?",
      "english_translation": "And what can make you know what is the Striking Calamity?",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 4,
      "arabic_text": "يَوْمَ يَكُونُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوثِ",
      "bangla_translation": "যেদিন মানুষ হবে বিক্ষিপ্ত পতংগের মত",
      "english_translation": "It is the Day when people will be like moths, dispersed,",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 5,
      "arabic_text": "وَتَكُونُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوشِ",
      "bangla_translation": "এবং পর্বতমালা হবে ধুনিত রঙ্গীন পশমের মত।",
      "english_translation": "And the mountains will be like wool, fluffed up.",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 6,
      "arabic_text": "فَأَمَّا مَنْ ثَقُلَتْ مَوَازِينُهُ",
      "bangla_translation": "অতএব যার পাল্লা ভারী হবে,",
      "english_translation": "Then as for one whose scales are heavy [with good deeds],",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 7,
      "arabic_text": "فَهُوَ فِي عِيشَةٍ رَاضِيَةٍ",
      "bangla_translation": "সে সুখীজীবন যাপন করবে।",
      "english_translation": "He will be in a pleasant life.",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 8,
      "arabic_text": "وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ",
      "bangla_translation": "আর যার পাল্লা হালকা হবে,",
      "english_translation": "But as for one whose scales are light,",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 9,
      "arabic_text": "فَأُمُّهُ هَاوِيَةٌ",
      "bangla_translation": "তার ঠিকানা হবে হাবিয়া।",
      "english_translation": "His refuge will be an abyss.",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 10,
      "arabic_text": "وَمَا أَدْرَاكَ مَا هِيَهْ",
      "bangla_translation": "আপনি জানেন তা কি?",
      "english_translation": "And what can make you know what that is?",
      "juz_number": 30,
      "page_number": 600
    },
    {
      "surah_number": 101,
      "ayah_number": 11,
      "arabic_text": "نَارٌ حَامِيَةٌ",
      "bangla_translation": "প্রজ্জ্বলিত অগ্নি!",
      "english_translation": "It is a Fire, intensely hot.",
      "juz_number": 30,
      "page_number": 600
    }
  ]
}
