{
  "surah": {
    "number": 88,
    "name_arabic": "سُورَةُ الغَاشِيَةِ",
    "name_bangla": "আল-গাশিয়াহ",
    "name_english": "Al-Ghaashiya",
    "name_meaning": "The Overwhelming",
    "ayah_count": 26,
    "juz_start": 30,
    "revelation_type": "meccan"
  },
  "ayahs": [
    {
      "surah_number": 88,
      "ayah_number": 1,
      "arabic_text": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ هَلْ أَتَاكَ حَدِيثُ الْغَاشِيَةِ",
      "bangla_translation": "আপনার কাছে আচ্ছন্নকারী কেয়ামতের বৃত্তান্ত পৌঁছেছে কি?",
      "english_translation": "Has there reached you the report of the Overwhelming [event]?",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 2,
      "arabic_text": "وُجُوهٌ يَوْمَئِذٍ خَاشِعَةٌ",
      "bangla_translation": "অনেক মুখমন্ডল সেদিন হবে লাঞ্ছিত,",
      "english_translation": "[Some] faces, that Day, will be humbled,",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 3,
      "arabic_text": "عَامِلَةٌ نَاصِبَةٌ",
      "bangla_translation": "ক্লিষ্ট, ক্লান্ত।",
      "english_translation": "Working [hard] and exhausted.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 4,
      "arabic_text": "تَصْلَىٰ نَارًا حَامِيَةً",
      "bangla_translation": "তারা জ্বলন্ত আগুনে পতিত হবে।",
      "english_translation": "They will [enter to] burn in an intensely hot Fire.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 5,
      "arabic_text": "تُسْقَىٰ مِنْ عَيْنٍ آنِيَةٍ",
      "bangla_translation": "তাদেরকে ফুটন্ত নহর থেকে পান করানো হবে।",
      "english_translation": "They will be given drink from a boiling spring.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 6,
      "arabic_text": "لَيْسَ لَهُمْ طَعَامٌ إِلَّا مِنْ ضَرِيعٍ",
      "bangla_translation": "কন্টকপূর্ণ ঝাড় ব্যতীত তাদের জন্যে কোন খাদ্য নেই।",
      "english_translation": "For them there will be no food except from a poisonous, thorny plant",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 7,
      "arabic_text": "لَا يُسْمِنُ وَلَا يُغْنِي مِنْ جُوعٍ",
      "bangla_translation": "এটা তাদেরকে পুষ্ট করবে না এবং ক্ষুধায়ও উপকার করবে না।",
      "english_translation": "Which neither nourishes nor avails against hunger.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 8,
      "arabic_text": "وُجُوهٌ يَوْمَئِذٍ نَاعِمَةٌ",
      "bangla_translation": "অনেক মুখমন্ডল সেদিন হবে, সজীব,",
      "english_translation": "[Other] faces, that Day, will show pleasure.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 9,
      "arabic_text": "لِسَعْيِهَا رَاضِيَةٌ",
      "bangla_translation": "তাদের কর্মের কারণে সন্তুষ্ট।",
      "english_translation": "With their effort [they are] satisfied",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 10,
      "arabic_text": "فِي جَنَّةٍ عَالِيَةٍ",
      "bangla_translation": "তারা থাকবে, সুউচ্চ জান্নাতে।",
      "english_translation": "In an elevated garden,",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 11,
      "arabic_text": "لَا تَسْمَعُ فِيهَا لَاغِيَةً",
      "bangla_translation": "তথায় শুনবে না কোন অসার কথাবার্তা।",
      "english_translation": "Wherein they will hear no unsuitable speech.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 12,
      "arabic_text": "فِيهَا عَيْنٌ جَارِيَةٌ",
      "bangla_translation": "তথায় থাকবে প্রবাহিত ঝরণা।",
      "english_translation": "Within it is a flowing spring.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 13,
      "arabic_text": "فِيهَا سُرُرٌ مَرْفُوعَةٌ",
      "bangla_translation": "তথায় থাকবে উন্নত সুসজ্জিত আসন।",
      "english_translation": "Within it are couches raised high",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 14,
      "arabic_text": "وَأَكْوَابٌ مَوْضُوعَةٌ",
      "bangla_translation": "এবং সংরক্ষিত পানপাত্র",
      "english_translation": "And cups put in place",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 15,
      "arabic_text": "وَنَمَارِقُ مَصْفُوفَةٌ",
      "bangla_translation": "এবং সারি সারি গালিচা",
      "english_translation": "And cushions lined up",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 16,
      "arabic_text": "وَزَرَابِيُّ مَبْثُوثَةٌ",
      "bangla_translation": "এবং বিস্তৃত বিছানো কার্পেট।",
      "english_translation": "And carpets spread around.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 17,
      "arabic_text": "أَفَلَا يَنْظُرُونَ إِلَى الْإِبِلِ كَيْفَ خُلِقَتْ",
      "bangla_translation": "তারা কি উষ্ট্রের প্রতি লক্ষ্য করে না যে, তা কিভাবে সৃষ্টি করা হয়েছে?",
      "english_translation": "Then do they not look at the camels - how they are created?",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 18,
      "arabic_text": "وَإِلَى السَّمَاءِ كَيْفَ رُفِعَتْ",
      "bangla_translation": "এবং আকাশের প্রতি লক্ষ্য করে না যে, তা কিভাবে উচ্চ করা হয়েছে?",
      "english_translation": "And at the sky - how it is raised?",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 19,
      "arabic_text": "وَإِلَى الْجِبَالِ كَيْفَ نُصِبَتْ",
      "bangla_translation": "এবং পাহাড়ের দিকে যে, তা কিভাবে স্থাপন করা হয়েছে?",
      "english_translation": "And at the mountains - how they are erected?",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 20,
      "arabic_text": "وَإِلَى الْأَرْضِ كَيْفَ سُطِحَتْ",
      "bangla_translation": "এবং পৃথিবীর দিকে যে, তা কিভাবে সমতল বিছানো হয়েছে?",
      "english_translation": "And at the earth - how it is spread out?",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 21,
      "arabic_text": "فَذَكِّرْ إِنَّمَا أَنْتَ مُذَكِّرٌ",
      "bangla_translation": "অতএব, আপনি উপদেশ দিন, আপনি তো কেবল একজন উপদেশদাতা,",
      "english_translation": "So remind, [O Muhammad]; you are only a reminder.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 22,
      "arabic_text": "لَسْتَ عَلَيْهِمْ بِمُصَيْطِرٍ",
      "bangla_translation": "আপনি তাদের শাসক নন,",
      "english_translation": "You are not over them a controller.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 23,
      "arabic_text": "إِلَّا مَنْ تَوَلَّىٰ وَكَفَرَ",
      "bangla_translation": "কিন্তু যে মুখ ফিরিয়ে নেয় ও কাফের হয়ে যায়,",
      "english_translation": "However, he who turns away and disbelieves -",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 24,
      "arabic_text": "فَيُعَذِّبُهُ اللَّهُ الْعَذَابَ الْأَكْبَرَ",
      "bangla_translation": "আল্লাহ তাকে মহা আযাব দেবেন।",
      "english_translation": "Then Allah will punish him with the greatest punishment.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 25,
      "arabic_text": "إِنَّ إِلَيْنَا إِيَابَهُمْ",
      "bangla_translation": "নিশ্চয় তাদের প্রত্যাবর্তন আমারই নিকট,",
      "english_translation": "Indeed, to Us is their return.",
      "juz_number": 30,
      "page_number": 592
    },
    {
      "surah_number": 88,
      "ayah_number": 26,
      "arabic_text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُمْ",
      "bangla_translation": "অতঃপর তাদের হিসাব-নিকাশ আমারই দায়িত্ব।",
      "english_translation": "Then indeed, upon Us is their account.",
      "juz_number": 30,
      "page_number": 592
    }
  ]
}
